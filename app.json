{
  "expo": {
    "name": "Clean Pro",
    "slug": "clean-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/clean-pro-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/clean-pro-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F3F8FF"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.cleanpro.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/clean-pro-icon.png",
        "backgroundColor": "#1B6FC4"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/clean-pro-icon.png",
      "bundler": "metro"
    },
    "extra": {},
    "plugins": [
      "expo-font",
      "@sentry/react-native/expo",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Clean Pro uses your location to set your pickup address on the map."
        }
      ]
    ],
    "owner": "clean-pro"
  }
}
