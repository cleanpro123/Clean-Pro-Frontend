{
  "expo": {
    "name": "Clean Pro",
    "slug": "clean-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F3F8FF"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.cleanpro.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B6FC4"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {},
    "plugins": [
      "expo-font",
      "@sentry/react-native/expo",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Clean Pro uses your location to set your pickup address on the map."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Clean Pro uses your photos so you can set a profile picture."
        }
      ]
    ],
    "owner": "mhdnihal"
  }
}
