{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": { "EXPO_PUBLIC_APP_VARIANT": "user", "SENTRY_DISABLE_AUTO_UPLOAD": "true" }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": { "EXPO_PUBLIC_APP_VARIANT": "user", "SENTRY_DISABLE_AUTO_UPLOAD": "true" }
    },
    "production": {
      "autoIncrement": true,
      "env": { "EXPO_PUBLIC_APP_VARIANT": "user", "SENTRY_DISABLE_AUTO_UPLOAD": "true" }
    },

    "development-partner": {
      "developmentClient": true,
      "distribution": "internal",
      "env": { "EXPO_PUBLIC_APP_VARIANT": "partner", "SENTRY_DISABLE_AUTO_UPLOAD": "true" }
    },
    "preview-partner": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": { "EXPO_PUBLIC_APP_VARIANT": "partner", "SENTRY_DISABLE_AUTO_UPLOAD": "true" }
    },
    "production-partner": {
      "autoIncrement": true,
      "env": { "EXPO_PUBLIC_APP_VARIANT": "partner", "SENTRY_DISABLE_AUTO_UPLOAD": "true" }
    }
  },
  "submit": {
    "production": {},
    "production-partner": {}
  }
}
